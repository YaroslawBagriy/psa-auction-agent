LOG_LEVEL=INFO
APP_DATABASE_PATH=data/psa_pokemon_bidder.db

# Toggle mock/live adapters
USE_LIVE_EBAY=false
POLL_INTERVAL_MINUTES=15
EBAY_SCAN_LIMIT=100

# eBay listing ingestion
EBAY_ENVIRONMENT=production
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_OFFICIAL_SELLER_NAME=psa
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_DEV_ID=
EBAY_RU_NAME=
EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope
EBAY_ACCESS_TOKEN=
EBAY_ACCESS_TOKEN_EXPIRES_AT=
EBAY_ENRICH_LISTING_PAGE=true
EBAY_LISTING_PAGE_TIMEOUT_SECONDS=5

# eBay market comp research
EBAY_MARKET_RESEARCH_ENABLED=true
EBAY_MARKET_RESEARCH_ACTIVE_LIMIT=50
EBAY_MARKET_RESEARCH_SOLD_LIMIT=50
EBAY_MARKET_RESEARCH_TIMEOUT_SECONDS=20

# Sold-comp research uses eBay's limited-release Buy Marketplace Insights API.
# Keep disabled until eBay grants the buy.marketplace.insights scope.
EBAY_MARKETPLACE_INSIGHTS_ENABLED=false
EBAY_MARKETPLACE_INSIGHTS_SCOPE=https://api.ebay.com/oauth/api_scope/buy.marketplace.insights
EBAY_MARKETPLACE_INSIGHTS_ACCESS_TOKEN=

# MVP bidding is manual by default. Automated official API bidding requires eBay approval.
EBAY_BIDDING_MODE=manual
# allowed values: manual, official_api, browser_automation
EBAY_BIDDING_ENABLED=false
EBAY_REQUIRE_HUMAN_CONFIRMATION=true
EBAY_OPEN_LISTING_ON_MANUAL=false
EBAY_BID_CURRENCY=USD
EBAY_OFFER_API_TIMEOUT_SECONDS=20

# Browser automation bidding is intentionally unsupported and must remain false in MVP.
EBAY_BROWSER_AUTOMATION_ENABLED=false

# User OAuth values for https://api.ebay.com/oauth/api_scope/buy.offer.auction.
# Required only for approved official_api bidding. Access token can be short-lived;
# refresh token lets the app mint a fresh user access token through eBay OAuth.
EBAY_USER_ACCESS_TOKEN=
EBAY_USER_REFRESH_TOKEN=
EBAY_USER_ACCESS_TOKEN_EXPIRES_AT=

# Legacy Trading API values retained only for compatibility/future experimentation.
# Do not rely on these for MVP bidding.
EBAY_TRADING_SITE_ID=0
EBAY_TRADING_COMPATIBILITY_LEVEL=1423

# Official Buy Offer API / proxy bidding settings.
# Requires limited-release eBay approval before production bids will work.
EBAY_BUY_OFFER_API_ENABLED=false
EBAY_BUY_OFFER_SCOPE=https://api.ebay.com/oauth/api_scope/buy.offer.auction

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
