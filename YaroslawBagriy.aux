\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces A failure case that improved the project. The LLM saw incompatible sold-price clusters and over-valued the card. The final version now tells the market-research and analysis agents to reject unverified high-price clusters, and deterministic guardrails cap values using lower sold comps.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:outlier}{{3}{5}{A failure case that improved the project. The LLM saw incompatible sold-price clusters and over-valued the card. The final version now tells the market-research and analysis agents to reject unverified high-price clusters, and deterministic guardrails cap values using lower sold comps}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces A later Garchomp review included market evidence fields such as active listing count, estimated market value, recent sold prices, sell-through rate, and a denial reason. This illustrates the move from free-form prose to structured evidence.}}{5}{figure.4}\protected@file@percent }
\newlabel{fig:garchomp-context}{{4}{5}{A later Garchomp review included market evidence fields such as active listing count, estimated market value, recent sold prices, sell-through rate, and a denial reason. This illustrates the move from free-form prose to structured evidence}{figure.4}{}}
